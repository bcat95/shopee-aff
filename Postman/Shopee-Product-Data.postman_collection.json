                            "value": "{{item_id}}"
                        }
                    ]
                },
                "description": "Get product data by item_id."
            },
            "response": []
        },
        {
            "name": "GET - By URL",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}?url={{product_url}}",
                    "host": ["{{base_url}}"],
                    "query": [
                        {
                            "key": "url",
                            "value": "{{product_url}}"
                        }
                    ]
                },
                "description": "Get product data by full Shopee product URL."
            },
            "response": []
        },
        {
            "name": "POST - x-www-form-urlencoded (item_id)",
            "request": {
                "method": "POST",
                "header": [],
                "body": {
                    "mode": "urlencoded",
                    "urlencoded": [
